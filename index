<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Today Platina · Dashboard</title>
<style>
/* ── TOKENS ─────────────────────────────────────────────────────────────── */
:root {
  --navy:      #0D1B3E;
  --navy-mid:  #162347;
  --navy-lt:   #1E2D5A;
  --bg:        #F8FAFC;
  --off-white: #F4F6FA;
  --gold:      #D4A017;
  --gold-lt:   #F0C030;
  --green:     #16A34A;
  --green-lt:  #DCFCE7;
  --teal:      #0D9488;
  --teal-lt:   #CCFBF1;
  --red:       #DC2626;
  --red-lt:    #FEE2E2;
  --orange:    #EA580C;
  --orange-lt: #FEF3C7;
  --purple:    #7C3AED;
  --blue:      #5B8DEF;
  --blue-lt:   #EFF6FF;
  --white:     #FFFFFF;
  --slate:     #64748B;
  --slate-l:   #94A3B8;
  --border:    #E2E8F0;
  --text:      #1E293B;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
       background: var(--bg); color: var(--text); min-height: 100vh; }

/* ── LOGIN ──────────────────────────────────────────────────────────────── */
#login-screen {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-lt) 100%);
}
.login-box {
  background: var(--navy-mid); border: 1px solid var(--navy-lt);
  border-radius: 20px; padding: 52px 44px; width: 380px; text-align: center;
  box-shadow: 0 32px 80px rgba(0,0,0,.5);
}
.login-eyebrow { font-size: 11px; letter-spacing: .25em; color: var(--gold);
                 text-transform: uppercase; margin-bottom: 10px; }
.login-title { font-size: 28px; font-weight: 800; color: var(--white); margin-bottom: 8px; }
.login-sub { font-size: 13px; color: var(--slate-l); margin-bottom: 36px; }
.login-box input {
  width: 100%; padding: 13px 16px; border-radius: 10px;
  border: 1px solid var(--navy-lt); background: var(--navy);
  color: var(--white); font-size: 15px; margin-bottom: 12px;
  outline: none; transition: border-color .2s; letter-spacing: .08em;
}
.login-box input:focus { border-color: var(--gold); }
.login-box button {
  width: 100%; padding: 13px; border-radius: 10px; border: none;
  background: var(--gold); color: var(--navy); font-size: 15px;
  font-weight: 800; cursor: pointer; transition: background .2s; margin-top: 4px;
}
.login-box button:hover { background: var(--gold-lt); }
.login-error { color: var(--red); font-size: 12px; margin-top: 10px; display: none; }

/* ── APP ────────────────────────────────────────────────────────────────── */
#app { display: none; }

/* ── HEADER ─────────────────────────────────────────────────────────────── */
.header {
  background: var(--navy); border-bottom: 3px solid var(--gold);
  padding: 0 32px; position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between; height: 56px;
}
.header-brand { display: flex; align-items: center; gap: 14px; }
.header-eyebrow { font-size: 10px; letter-spacing: .22em; color: var(--gold);
                  text-transform: uppercase; }
.header-title { font-size: 16px; font-weight: 700; color: var(--white); }
.header-meta { font-size: 11px; color: var(--slate-l); }
.header-nav { display: flex; gap: 2px; }
.nav-btn {
  padding: 7px 13px; border-radius: 6px; border: none;
  background: transparent; color: var(--slate-l); font-size: 12px;
  font-weight: 500; cursor: pointer; transition: all .15s; white-space: nowrap;
}
.nav-btn:hover { color: var(--white); background: var(--navy-lt); }
.nav-btn.active { color: var(--navy); background: var(--gold); font-weight: 700; }

/* ── SLIDES ─────────────────────────────────────────────────────────────── */
.slide { display: none; padding: 40px 32px; max-width: 1160px; margin: 0 auto; }
.slide.active { display: block; }
.slide-eyebrow { font-size: 10px; letter-spacing: .2em; color: var(--gold);
                 text-transform: uppercase; margin-bottom: 6px; font-weight: 700; }
.slide-title { font-size: 28px; font-weight: 800; color: var(--navy); line-height: 1.15; }
.slide-sub { font-size: 14px; color: var(--slate); margin-top: 8px; }
.slide-hdr { margin-bottom: 32px; }

/* ── KPI STRIP ──────────────────────────────────────────────────────────── */
.kpi-strip { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 32px; }
.kpi-card {
  background: var(--navy); border-radius: 14px; padding: 22px 18px 18px;
  text-align: center; position: relative; overflow: hidden;
}
.kpi-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:4px;
  background: var(--accent, var(--gold));
}
.kpi-val { font-size: 40px; font-weight: 900; color: var(--accent, var(--gold)); line-height: 1; }
.kpi-label { font-size: 11px; color: var(--slate-l); margin-top: 8px; letter-spacing: .04em; }

/* ── FUNIL ───────────────────────────────────────────────────────────────── */
.funil-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; margin-bottom: 28px; }
.funil-card {
  border-radius: 14px; padding: 20px 16px; text-align: center;
  border: 1.5px solid var(--fc-border, var(--border));
  background: var(--fc-bg, var(--off-white));
}
.funil-num { font-size: 11px; font-weight: 800; color: var(--fc-color, var(--slate));
             letter-spacing: .08em; margin-bottom: 8px; }
.funil-val { font-size: 38px; font-weight: 900; color: var(--fc-color, var(--slate)); line-height: 1; }
.funil-name { font-size: 12px; font-weight: 700; color: var(--fc-color, var(--slate));
              margin-top: 6px; }
.funil-desc { font-size: 11px; color: var(--slate); margin-top: 4px; line-height: 1.4; }
.funil-note {
  background: var(--navy); border-radius: 12px; padding: 16px 20px;
  font-size: 13px; color: var(--gold-lt); line-height: 1.6;
}

/* ── EQUIPES ────────────────────────────────────────────────────────────── */
.equipes-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 32px; }
.equipe-card {
  background: var(--white); border-radius: 14px; padding: 22px 20px;
  border: 1.5px solid var(--border); border-top: 4px solid var(--ec-color, var(--blue));
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.eq-name { font-size: 10px; letter-spacing: .18em; color: var(--ec-color, var(--blue));
           text-transform: uppercase; font-weight: 800; margin-bottom: 10px; }
.eq-taxa { font-size: 38px; font-weight: 900; color: var(--ec-color, var(--blue));
           line-height: 1; }
.eq-taxa-lbl { font-size: 11px; color: var(--slate); margin-bottom: 12px; }
.eq-detail { font-size: 13px; color: var(--slate); margin-bottom: 14px; }
.eq-bar-bg { background: var(--border); border-radius: 4px; height: 6px; }
.eq-bar-fill { border-radius: 4px; height: 6px;
               background: var(--ec-color, var(--blue)); transition: width .8s ease; }

.ve-section { margin-top: 28px; }
.section-title { font-size: 10px; font-weight: 800; letter-spacing: .18em;
                 color: var(--slate); text-transform: uppercase; margin-bottom: 14px; }

/* ── BARRAS HORIZONTAIS ─────────────────────────────────────────────────── */
.bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
.bar-label { font-size: 12px; font-weight: 600; color: var(--text);
             width: 120px; flex-shrink: 0; }
.bar-track { flex: 1; background: var(--border); border-radius: 6px; height: 22px;
             position: relative; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 6px; transition: width .7s ease;
            display: flex; align-items: center; padding-left: 10px; }
.bar-fill span { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.9);
                 white-space: nowrap; }
.bar-meta { font-size: 12px; color: var(--slate); width: 90px; flex-shrink: 0;
            text-align: right; }

/* ── SUPERS ─────────────────────────────────────────────────────────────── */
.super-table { width: 100%; border-collapse: collapse; }
.super-table thead th {
  padding: 10px 14px; text-align: right; font-size: 10px; letter-spacing: .1em;
  color: var(--white); text-transform: uppercase; background: var(--navy);
}
.super-table thead th:first-child { text-align: left; border-radius: 10px 0 0 0; }
.super-table thead th:last-child { border-radius: 0 10px 0 0; }
.super-table tbody tr { border-bottom: 1px solid var(--border); }
.super-table tbody tr:hover td { background: var(--off-white); }
.super-table td { padding: 10px 14px; text-align: right; font-size: 13px; color: var(--slate); }
.super-table td:first-child { text-align: left; font-weight: 700; color: var(--navy); }
.super-table .bar-cell { min-width: 140px; }
.super-wrap { background: var(--white); border-radius: 14px; border: 1.5px solid var(--border);
              overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.04); }

/* ── TIPOS DE VISITA ────────────────────────────────────────────────────── */
.tipos-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 32px; }
.tipo-card {
  background: var(--white); border-radius: 14px; padding: 24px 20px;
  border: 1.5px solid var(--tc-border, var(--border));
  border-top: 4px solid var(--tc-color, var(--teal));
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.tc-label { font-size: 10px; letter-spacing: .18em; font-weight: 800;
            color: var(--tc-color); text-transform: uppercase; margin-bottom: 10px; }
.tc-pct { font-size: 42px; font-weight: 900; color: var(--tc-color); line-height: 1; }
.tc-sub { font-size: 12px; color: var(--slate); margin-top: 6px; }

/* Bicolor bars */
.bicolor-section { margin-top: 32px; }
.bicolor-header { display: grid; grid-template-columns: 140px 1fr 1fr 1fr;
                  gap: 8px; margin-bottom: 8px; }
.bc-col-hdr { font-size: 10px; font-weight: 800; letter-spacing: .12em;
              text-transform: uppercase; padding: 6px 8px; border-radius: 6px;
              text-align: center; }
.bicolor-row { display: grid; grid-template-columns: 140px 1fr 1fr 1fr;
               gap: 8px; margin-bottom: 4px; align-items: center; }
.bicolor-row:nth-child(odd) .bc-name { color: var(--navy); }
.bc-name { font-size: 13px; font-weight: 700; color: var(--navy);
           padding: 8px 0; }
.bc-eq { font-size: 11px; color: var(--slate); }
.bc-bar-wrap { padding: 4px 0; }
.bc-track { height: 20px; border-radius: 6px; position: relative;
            overflow: hidden; background: var(--border); }
.bc-fill-bg { height: 100%; border-radius: 6px; position: absolute;
              left: 0; top: 0; }
.bc-fill-qv { height: 100%; border-radius: 6px; position: absolute;
              left: 0; top: 0; }
.bc-meta { display: flex; justify-content: space-between;
           margin-top: 4px; font-size: 11px; }
.bc-pct { font-weight: 700; }
.bc-frac { color: var(--slate); }

/* ── SEMANAL ────────────────────────────────────────────────────────────── */
.semanas-grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
                margin-bottom: 32px; }
.sem-card {
  background: var(--white); border-radius: 14px; padding: 20px 16px;
  border: 1.5px solid var(--border); text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.sem-card.current { border-color: var(--orange); background: #FFF7F0; }
.sem-period { font-size: 11px; font-weight: 700; color: var(--slate);
              margin-bottom: 14px; letter-spacing: .04em; }
.sem-atend { font-size: 38px; font-weight: 900; color: var(--blue); line-height: 1; }
.sem-atend-lbl { font-size: 10px; color: var(--slate-l); margin-bottom: 10px; }
.sem-divider { border: none; border-top: 1px solid var(--border); margin: 10px 0; }
.sem-qv { font-size: 32px; font-weight: 900; line-height: 1; }
.sem-qv-lbl { font-size: 11px; font-weight: 700; margin-top: 4px; }
.sem-note { font-size: 11px; color: var(--slate); margin-top: 10px; line-height: 1.4; }

/* Bar chart semanal */
.sem-chart { background: var(--white); border-radius: 14px; border: 1.5px solid var(--border);
             padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,.04); }
.sem-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.sem-bar-lbl { font-size: 11px; color: var(--slate); width: 90px; flex-shrink: 0; }
.sem-bar-area { flex: 1; }
.sem-stacked { height: 22px; border-radius: 6px; background: var(--border);
               position: relative; overflow: hidden; }
.sem-bar-total { height: 100%; border-radius: 6px; position: absolute;
                 background: var(--blue); opacity: .85; left: 0; }
.sem-bar-qv { height: 100%; border-radius: 6px; position: absolute;
              background: var(--green); left: 0; }
.sem-bar-meta { font-size: 11px; color: var(--slate); margin-top: 2px; }

/* ── PASTAS ─────────────────────────────────────────────────────────────── */
.pastas-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.pasta-panel {
  background: var(--white); border-radius: 14px; border: 2px solid var(--pp-color, var(--teal));
  overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.pasta-header { background: var(--pp-color, var(--teal)); padding: 16px 20px; }
.pasta-header h3 { font-size: 14px; font-weight: 800; color: var(--white); }
.pasta-header p { font-size: 12px; color: rgba(255,255,255,.75); margin-top: 2px; }
.pasta-kpis { display: grid; grid-template-columns: repeat(4,1fr); padding: 20px;
              gap: 8px; border-bottom: 1px solid var(--border); }
.pk { text-align: center; }
.pk-val { font-size: 28px; font-weight: 900; color: var(--pp-color, var(--teal)); }
.pk-lbl { font-size: 10px; color: var(--slate); margin-top: 4px; text-transform: uppercase;
          letter-spacing: .08em; }
.pasta-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.pasta-table th { background: var(--off-white); padding: 8px 14px; font-size: 10px;
                  text-transform: uppercase; letter-spacing: .08em; color: var(--slate);
                  text-align: right; border-bottom: 1px solid var(--border); }
.pasta-table th:first-child { text-align: left; }
.pasta-table td { padding: 9px 14px; text-align: right; border-bottom: 1px solid var(--border); }
.pasta-table td:first-child { text-align: left; font-weight: 600; color: var(--navy); }
.pasta-table tr:last-child td { font-weight: 800; color: var(--navy);
                                 background: var(--off-white); border-bottom: none; }
.pasta-note { padding: 12px 20px; font-size: 12px; color: var(--slate);
              border-top: 1px solid var(--border); }

/* ── FOOTER ─────────────────────────────────────────────────────────────── */
.footer { background: var(--navy); color: var(--slate-l); text-align: center;
          padding: 16px; font-size: 11px; margin-top: 40px; letter-spacing: .04em; }

  @media (max-width: 768px) {
    .midia-grupos > div { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 400px) {
    .midia-grupos > div { grid-template-columns: 1fr !important; }
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-eyebrow">Canopus Construtora</div>
    <div class="login-title">Today Platina</div>
    <div class="login-sub">Dashboard de Qualificação · Acesso restrito</div>
    <input type="password" id="pwd-input" placeholder="Senha de acesso"
           onkeydown="if(event.key==='Enter')doLogin()">
    <button onclick="doLogin()">Entrar</button>
    <div class="login-error" id="login-error">Senha incorreta</div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <header class="header">
    <div class="header-brand">
      <div>
        <div class="header-eyebrow">Canopus · Today Platina</div>
        <div class="header-title">Dashboard de Qualificação</div>
      </div>
    </div>
    <nav class="header-nav">
      <button class="nav-btn active" onclick="goSlide(0,this)">Visão Geral</button>
      <button class="nav-btn" onclick="goSlide(1,this)">Metodologia</button>
      <button class="nav-btn" onclick="goSlide(2,this)">Equipes</button>
      <button class="nav-btn" onclick="goSlide(3,this)">Tipo de Visita</button>
      <button class="nav-btn" onclick="goSlide(4,this)">Ranking QV</button>
      <button class="nav-btn" onclick="goSlide(5,this)">Semanal</button>
      <button class="nav-btn" onclick="goSlide(6,this)">Mídia</button>
      <button class="nav-btn" onclick="goSlide(7,this)">Pastas</button>
    </nav>
  </header>

  <!-- S0: CAPA -->
  <section class="slide active" id="s0">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Today Platina · Pré-Venda</div>
      <div class="slide-title">Relatório de Qualificação de Leads</div>
      <div class="slide-sub" id="s0-periodo">—</div>
    </div>
    <div class="kpi-strip" id="s0-kpis"></div>

    <div style="margin-top:32px">
      <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:14px">
        <div class="section-title" style="margin-bottom:0;font-size:14px;color:var(--navy)">📋 Fechamento do Dia</div>
        <div id="s0-fechamento-data" style="font-size:12px;color:var(--slate-l)">—</div>
      </div>
      <div style="background:var(--white);border-radius:14px;border:1.5px solid var(--border);overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)">
        <div id="s0-fechamento"></div>
      </div>
    </div>
  </section>

  <!-- S1: METODOLOGIA -->
  <section class="slide" id="s1">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Metodologia</div>
      <div class="slide-title">Como medimos qualificação?</div>
      <div class="slide-sub">Funil de 5 estágios — do primeiro contato à pasta aberta</div>
    </div>
    <div class="funil-grid" id="s1-funil"></div>
    <div class="funil-note" id="s1-note"></div>
  </section>

  <!-- S2: EQUIPES -->
  <section class="slide" id="s2">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Visão Geral · Equipes</div>
      <div class="slide-title">Performance por Equipe de Vendas</div>
      <div class="slide-sub">Volume de atendimentos, qualificações e taxa QV</div>
    </div>
    <div class="equipes-grid" id="s2-cards"></div>
    <div class="ve-section">
      <div class="section-title">VE % por Equipe (Tráfego Orgânico)</div>
      <div id="s2-ve-bars"></div>
    </div>
  </section>

  <!-- S3: TIPOS DE VISITA -->
  <section class="slide" id="s3">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Qualificação QV · Tipos de Visita</div>
      <div class="slide-title">Como cada equipe converte por tipo de visita?</div>
      <div class="slide-sub">Barra longa = mais visitas · Parte escura = QVs geradas</div>
    </div>
    <div class="tipos-cards" id="s3-cards"></div>
    <div class="bicolor-section" id="s3-bicolor"></div>
  </section>

  <!-- S4: RANKING QV -->
  <section class="slide" id="s4">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Qualificação QV · Ranking</div>
      <div class="slide-title">Taxa QV por Superintendente / Empresa de Vendas</div>
      <div class="slide-sub">Ordenado por taxa de conversão decrescente</div>
    </div>
    <div class="super-wrap">
      <table class="super-table">
        <thead>
          <tr>
            <th style="text-align:left;width:160px">Super / Equipe</th>
            <th>Atend.</th>
            <th>QVs</th>
            <th style="width:200px;text-align:left;padding-left:16px">Taxa QV %</th>
            <th style="text-align:right">Status</th>
          </tr>
        </thead>
        <tbody id="s4-tbody"></tbody>
      </table>
    </div>
  </section>

  <!-- S5: SEMANAL -->
  <section class="slide" id="s5">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Tendência · Evolução Semanal</div>
      <div class="slide-title">Evolução por Semana: Atendimentos e QV</div>
      <div class="slide-sub">Dados acumulados por semana (seg–dom)</div>
    </div>
    <div class="semanas-grid" id="s5-cards"></div>
    <div class="sem-chart">
      <div class="section-title" style="margin-bottom:16px">Comparativo Visual — Atendimentos vs QV</div>
      <div id="s5-bars"></div>
    </div>
  </section>


  <!-- S6: MÍDIA -->
  <section class="slide" id="s6">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Mídia de Origem · Análise de Canal</div>
      <div class="slide-title">De onde vêm os clientes que qualificam?</div>
      <div class="slide-sub">Classificação da mídia de origem × taxa QV — acumulado mai–jun/2026</div>
    </div>
    <div class="midia-grupos" id="s6-grupos"></div>
    <div style="margin-top:28px">
      <div class="section-title">Detalhe por Canal de Mídia</div>
      <div style="background:var(--white);border-radius:14px;border:1.5px solid var(--border);overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.04)">
        <div id="s6-tabela"></div>
      </div>
    </div>
  </section>

  <!-- S7: PASTAS -->
  <section class="slide" id="s7">
    <div class="slide-hdr">
      <div class="slide-eyebrow">Qualificação · Status de Pastas</div>
      <div class="slide-title">Pastas por Modalidade de Financiamento</div>
      <div class="slide-sub" id="s7-sub">—</div>
    </div>
    <div class="pastas-grid" id="s7-pastas"></div>
  </section>

  <footer class="footer" id="footer-bar">Today Platina · Canopus Construtora · CONFIDENCIAL</footer>
</div>

<script>
// ── AUTH ─────────────────────────────────────────────────────────────────────
const SENHA = 'platina2026';
function doLogin() {
  const v = document.getElementById('pwd-input').value;
  if (v === SENHA) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    loadData();
  } else {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('pwd-input').value = '';
  }
}

// ── NAVEGAÇÃO ────────────────────────────────────────────────────────────────
function goSlide(i, btn) {
  document.querySelectorAll('.slide').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('s' + i).classList.add('active');
  btn.classList.add('active');
}

// ── LOAD DATA ────────────────────────────────────────────────────────────────
const JSON_URL = 'https://raw.githubusercontent.com/mc3l0/today-platina-dashboard/main/platina_data.json';

function loadData() {
  fetch(JSON_URL + '?t=' + Date.now())
    .then(r => r.json())
    .then(d => {
      document.getElementById('footer-bar').textContent =
        'Today Platina · Canopus Construtora · Atualizado ' + d.gerado_em + ' · CONFIDENCIAL';
      renderAll(d);
    })
    .catch(() => {
    });
}

// ── HELPERS ──────────────────────────────────────────────────────────────────
function n(v) { return Number(v) || 0; }
function pct(a, b) { return b > 0 ? Math.round(a/b*1000)/10 : 0; }
function pctFmt(v) { return v.toFixed(1) + '%'; }
const COLORS = {
  HOUSE:     '#5B8DEF',
  'UP HOUSE':'#0D9488',
  MEDI:      '#EA580C',
  PARCERIAS: '#7C3AED',
};
const SUPER_EQ = {
  Ricardo:'HOUSE', Nelma:'HOUSE', Jamil:'HOUSE',
  Rodrigo:'PARCERIAS', Berillo:'PARCERIAS',
  'Up House':'UP HOUSE', Medi:'MEDI'
};

function statusColor(taxa) {
  if (taxa >= 40) return '#16A34A';
  if (taxa >= 30) return '#0D9488';
  if (taxa >= 20) return '#D4A017';
  return '#EA580C';
}
function statusLabel(taxa) {
  if (taxa >= 40) return '★ DESTAQUE';
  if (taxa >= 30) return 'BOM';
  if (taxa >= 20) return 'ATENÇÃO';
  return 'ABAIXO';
}

// ── RENDER ALL ───────────────────────────────────────────────────────────────
function renderAll(d) {
  renderS0(d);
  renderS1(d);
  renderS2(d);
  renderS3(d);
  renderS4(d);
  renderS5(d);
  renderS6(d);
  renderS7(d);
}

