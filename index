// ── S2: EQUIPES ──────────────────────────────────────────────────────────────
function renderS2(d) {
  const eqs = d.equipes || [];
  const maxAtend = Math.max(...eqs.map(e => e.atend));

  const eqColors = { HOUSE:'#5B8DEF','UP HOUSE':'#0D9488', MEDI:'#EA580C', PARCERIAS:'#7C3AED' };

  document.getElementById('s2-cards').innerHTML = eqs.map(e => {
    const c = eqColors[e.nome] || '#5B8DEF';
    return `<div class="equipe-card" style="--ec-color:${c}">
      <div class="eq-name">${e.nome}</div>
      <div class="eq-taxa">${pctFmt(e.taxa_qv)}</div>
      <div class="eq-taxa-lbl">taxa QV</div>
      <div class="eq-detail">${e.atend} atend &nbsp;·&nbsp; ${e.qv} QVs</div>
      <div class="eq-bar-bg">
        <div class="eq-bar-fill" style="width:${e.atend/maxAtend*100}%"></div>
      </div>
    </div>`;
  }).join('');

  // VE bars (apenas equipes com VE > 0, exceto PARCERIAS)
  const eqsVE = eqs.filter(e => e.nome !== 'PARCERIAS' && e.ve_pct > 0);
  const maxVE = Math.max(...eqsVE.map(e => e.ve_pct));
  document.getElementById('s2-ve-bars').innerHTML = eqsVE.map(e => {
    const c = eqColors[e.nome] || '#0D9488';
    return `<div class="bar-row">
      <div class="bar-label">${e.nome}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width:${e.ve_pct/maxVE*100}%;background:${c}">
          <span>${pctFmt(e.ve_pct)}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

// ── S3: TIPOS DE VISITA ───────────────────────────────────────────────────────
function renderS3(d) {
  const tipos = d.tipos || [];
  const tipoCfg = {
    I:  { label:'QV por Indicação',          color:'#7C3AED', border:'#C4B5FD', icon:'🤝' },
    VE: { label:'QV por Visita Espontânea',  color:'#0D9488', border:'#99E6DD', icon:'🚶' },
    R:  { label:'QV por Retorno',            color:'#16A34A', border:'#86EFAC', icon:'↩'  },
  };

  document.getElementById('s3-cards').innerHTML = tipos.map(t => {
    const cfg = tipoCfg[t.tipo] || {};
    return `<div class="tipo-card" style="--tc-color:${cfg.color};--tc-border:${cfg.border}">
      <div class="tc-label">${cfg.icon || ''} ${cfg.label || t.tipo}</div>
      <div class="tc-pct">${pctFmt(t.pct)}</div>
      <div class="tc-sub">${t.total} atend · ${t.qv} QV</div>
    </div>`;
  }).join('');

  // Bicolor por super
  const supers = d.supers || [];
  if (!supers.length) return;

  // Escala = SOMA total de cada tipo (participação proporcional ao total global)
  const totalT = { I:  supers.reduce((acc,s) => acc + s.I.total,  0),
                   VE: supers.reduce((acc,s) => acc + s.VE.total, 0),
                   R:  supers.reduce((acc,s) => acc + s.R.total,  0) };

  const tipoCols = [
    { k:'I',  fg:'#7C3AED', bg:'#C4B5FD', lbl:'INDICAÇÃO (I)' },
    { k:'VE', fg:'#0D9488', bg:'#99E6DD', lbl:'VE' },
    { k:'R',  fg:'#16A34A', bg:'#86EFAC', lbl:'RETORNO (R)' },
  ];

  const hdrHtml = `<div class="bicolor-header">
    <div></div>
    ${tipoCols.map(tc => `<div class="bc-col-hdr" style="background:${tc.fg}20;color:${tc.fg}">${tc.lbl}</div>`).join('')}
  </div>`;

  const rowsHtml = supers.map((s, i) => {
    const eq = SUPER_EQ[s.nome] || '';
    const eqColor = COLORS[eq] || '#5B8DEF';
    const cells = tipoCols.map(tc => {
      const td = s[tc.k];
      if (!td || td.total === 0) return `<div class="bc-bar-wrap"><div class="bc-track" style="background:#F1F5F9"><div style="font-size:10px;color:#CBD5E1;padding:2px 8px;line-height:18px">—</div></div></div>`;
      const volW = totalT[tc.k] > 0 ? td.total / totalT[tc.k] * 100 : 0;
      const qvW  = td.total > 0   ? td.qv    / td.total   * 100 : 0;
      const pctColor = td.pct >= 45 ? '#16A34A' : td.pct >= 25 ? '#0D9488' : td.pct > 0 ? '#EA580C' : '#94A3B8';
      return `<div class="bc-bar-wrap">
        <div class="bc-track">
          <div class="bc-fill-bg" style="width:${volW}%;background:${tc.bg}"></div>
          <div class="bc-fill-qv" style="width:${volW*qvW/100}%;background:${tc.fg}"></div>
        </div>
        <div class="bc-meta">
          <span class="bc-pct" style="color:${pctColor}">${pctFmt(td.pct)}</span>
          <span class="bc-frac">${td.qv}/${td.total}</span>
        </div>
      </div>`;
    }).join('');

    return `<div class="bicolor-row" style="background:${i%2===0?'#F8FAFC':'#FFF'}">
      <div class="bc-name" style="color:${eqColor}">${s.nome}<br><span class="bc-eq">${eq}</span></div>
      ${cells}
    </div>`;
  }).join('');

  document.getElementById('s3-bicolor').innerHTML = `
    <div class="section-title">Taxa QV por Super × Tipo de Visita</div>
    <div style="background:var(--white);border-radius:14px;border:1.5px solid var(--border);overflow:hidden;padding:16px 12px;box-shadow:0 2px 8px rgba(0,0,0,.04)">
      ${hdrHtml}${rowsHtml}
    </div>`;
}

// ── S4: RANKING QV ────────────────────────────────────────────────────────────
function renderS4(d) {
  const supers = d.supers || [];
  const maxAtend = Math.max(...supers.map(s => s.atend));

  document.getElementById('s4-tbody').innerHTML = supers.map((s, i) => {
    const eq = SUPER_EQ[s.nome] || '';
    const eqColor = COLORS[eq] || '#5B8DEF';
    const sc = statusColor(s.taxa_qv);
    const sl = statusLabel(s.taxa_qv);
    const barW = s.taxa_qv / 60 * 100; // escala até 60%
    const isJamil = s.nome === 'Jamil';
    return `<tr>
      <td>
        <span style="font-weight:800;color:${eqColor}">${s.nome}${isJamil?' *':''}</span>
        <br><span style="font-size:11px;color:var(--slate-l);font-weight:400">${eq}</span>
      </td>
      <td>${s.atend}</td>
      <td style="font-weight:800;color:${sc}">${s.qv}</td>
      <td style="text-align:left;padding-left:16px">
        <div style="display:flex;align-items:center;gap:10px">
          <div style="flex:1;background:var(--border);border-radius:4px;height:14px;overflow:hidden">
            <div style="width:${barW}%;height:100%;background:${sc};border-radius:4px;transition:width .7s ease"></div>
          </div>
          <span style="font-size:13px;font-weight:800;color:${sc};width:48px">${pctFmt(s.taxa_qv)}</span>
        </div>
      </td>
      <td><span style="font-size:11px;font-weight:800;color:${sc};background:${sc}18;padding:3px 10px;border-radius:20px;white-space:nowrap">${sl}</span></td>
    </tr>`;
  }).join('') +
  `<tr><td colspan="5" style="padding:10px 14px;font-size:11px;color:var(--slate);background:var(--off-white)">
    * Jamil: início mai/2026 — amostra insuficiente para comparação formal.
    &nbsp;|&nbsp; DESTAQUE ≥40% &nbsp;|&nbsp; BOM 30–39% &nbsp;|&nbsp; ATENÇÃO 20–29% &nbsp;|&nbsp; ABAIXO &lt;20%
  </td></tr>`;
}

// ── S5: SEMANAL ───────────────────────────────────────────────────────────────
function renderS5(d) {
  const sems = d.semanal || [];
  const maxAtend = Math.max(...sems.map(s => s.atend));
  const notas = [
    'Abertura — pico de qualificação.',
    'Maior volume do período. QV estável.',
    'Volume cai pela metade. QV segue tendência.',
    'Volume baixo, mas QV se sustenta.',
    'Primeiro sinal de recuperação — monitorar.',
    'Semana em andamento.',
  ];

  document.getElementById('s5-cards').innerHTML = sems.map((s, i) => {
    const isCurrent = i === sems.length - 1 && s.atend < 30;
    const qvColor = s.pct >= 40 ? '#16A34A' : s.pct >= 25 ? '#0D9488' : '#EA580C';
    return `<div class="sem-card${isCurrent?' current':''}">
      <div class="sem-period">${s.periodo}</div>
      <div class="sem-atend">${s.atend}</div>
      <div class="sem-atend-lbl">atendimentos</div>
      <hr class="sem-divider">
      <div class="sem-qv" style="color:${qvColor}">${s.qv}</div>
      <div class="sem-qv-lbl" style="color:${qvColor}">QV (${pctFmt(s.pct)})</div>
      <div class="sem-note">${notas[i] || ''}</div>
    </div>`;
  }).join('');

  document.getElementById('s5-bars').innerHTML = sems.map(s => {
    const totW = s.atend / maxAtend * 100;
    const qvW  = s.atend > 0 ? s.qv / s.atend * 100 : 0;
    return `<div class="sem-bar-row">
      <div class="sem-bar-lbl">${s.periodo}</div>
      <div class="sem-bar-area">
        <div class="sem-stacked">
          <div class="sem-bar-total" style="width:${totW}%"></div>
          <div class="sem-bar-qv" style="width:${totW*qvW/100}%"></div>
        </div>
        <div class="sem-bar-meta">${s.atend} atend · ${s.qv} QV (${pctFmt(s.pct)})</div>
      </div>
    </div>`;
  }).join('');
}


// ── S6: MÍDIA ─────────────────────────────────────────────────────────────────
function renderS6(d) {
  const orig = d.origem || [];
  if (!orig.length) return;

  // ── Classificação por grupo ──────────────────────────────────────────────
  const GRUPOS = {
    'DIGITAL': {
      emoji: '💻', canais: ['WHATSAPP','INSTAGRAM','SITE CANOPUS','GOOGLE','FACEBOOK','ONLINE','INTERNET','SDR'],
      color: '#0D9488', badge: '★ MELHOR QV%'
    },
    'OOH/IMPRESSO': {
      emoji: '🪧', canais: ['FOLHETO','BIRUTA','PAINEL LED','BANNER','FAIXA','JORNAL'],
      color: '#5B8DEF', badge: 'MAIOR VOLUME'
    },
    'ORGÂNICO/INDICAÇÃO': {
      emoji: '🤝', canais: ['VIZINHO','VIZINHA','CARTEIRA','INDICAÇÃO AMIGO','CAMPO','TELEFONE'],
      color: '#7C3AED', badge: 'ALTA EFICIÊNCIA'
    },

  };

  // Status por canal
  const STATUS = {
    'WHATSAPP':       { label:'DESTAQUE',    color:'#16A34A' },
    'INSTAGRAM':      { label:'↑ ASCENSÃO',  color:'#16A34A' },
    'SITE CANOPUS':   { label:'ÓTIMO',       color:'#0D9488' },
    'GOOGLE':         { label:'OK',          color:'#64748B' },
    'FACEBOOK':       { label:'ATENÇÃO',     color:'#EA580C' },
    'ONLINE':         { label:'OK',          color:'#64748B' },
    'INTERNET':       { label:'OK',          color:'#64748B' },
    'FOLHETO':        { label:'BOM',         color:'#5B8DEF' },
    'BIRUTA':         { label:'OK',          color:'#64748B' },
    'PAINEL LED':     { label:'ATENÇÃO',     color:'#EA580C' },
    'VIZINHO':        { label:'EFICIENTE',   color:'#0D9488' },
    'VIZINHA':        { label:'EFICIENTE',   color:'#0D9488' },
    'CARTEIRA':       { label:'DESTAQUE',    color:'#16A34A' },
    'INDICAÇÃO AMIGO':{ label:'BOM',         color:'#5B8DEF' },
    'CAMPO':          { label:'OK',          color:'#64748B' },
  };

  // Monta índice de dados por canal
  const byCanal = {};
  orig.forEach(o => byCanal[o.canal] = o);

  // ── Cards de grupo ──────────────────────────────────────────────────────
  const grupoEntries = Object.entries(GRUPOS);
  const grupoData = grupoEntries.map(([nome, g]) => {
    let atend=0, qv=0;
    g.canais.forEach(c => { if (byCanal[c]) { atend += byCanal[c].atend; qv += byCanal[c].qv; } });
    const taxa = (atend > 0 && !isNaN(qv/atend)) ? Math.round(qv/atend*1000)/10 : 0;
    return { nome, ...g, atend, qv, taxa };
  });

  document.getElementById('s6-grupos').innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:8px">
      ${grupoData.map(g => `
        <div style="background:var(--white);border:2px solid ${g.color};border-radius:14px;padding:20px;position:relative;overflow:hidden">
          <div style="font-size:12px;font-weight:700;color:${g.color};letter-spacing:.08em;margin-bottom:8px">${g.emoji} ${g.nome}</div>
          <div style="font-size:34px;font-weight:800;color:${g.taxa>=30?'#16A34A':g.taxa>=20?'#D4A017':'#EA580C'}">${g.taxa.toFixed(1)}%</div>
          <div style="font-size:11px;color:var(--slate-l);margin-bottom:8px">taxa QV</div>
          <div style="font-size:12px;color:var(--slate)">${g.atend} atend · ${g.qv} QV</div>
          <div style="margin-top:12px;background:${g.color};color:#fff;font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;display:inline-block;letter-spacing:.06em">${g.badge}</div>
        </div>`).join('')}
    </div>`;

  // ── Tabela detalhe ──────────────────────────────────────────────────────
  // maxAtend deve considerar grupos e canais para escala correta
  const grupoTotais = grupoData.map(g => g.atend);
  const maxAtend = Math.max(...grupoTotais, ...orig.map(o => o.atend));

  // Agrupa canais por grupo para a tabela
  const tabelaRows = [];
  grupoData.forEach(g => {
    // Linha de grupo (total)
    tabelaRows.push({ tipo:'grupo', nome: g.emoji + ' ' + g.nome + ' Total', atend: g.atend, qv: g.qv, taxa: g.taxa, color: g.color });
    // Linhas de canais individuais
    g.canais.forEach(c => {
      if (byCanal[c] && byCanal[c].atend > 0) {
        const st = STATUS[c] || { label:'—', color:'#64748B' };
        const cData = byCanal[c]; tabelaRows.push({ tipo:'canal', nome: '↳ ' + c.charAt(0)+c.slice(1).toLowerCase(), atend:cData.atend||0, qv:cData.qv||0, taxa:cData.taxa_qv||0, st });
      }
    });
  });

  // Total geral de atendimentos para calcular participação
  const totalAtend = orig.reduce((s, o) => s + o.atend, 0);

  const linhasHtml = tabelaRows.map(r => {
    const isGrupo = r.tipo === 'grupo';
    // Barra externa: participação no total de atendimentos
    const partPct = totalAtend > 0 ? Math.round(r.atend / totalAtend * 100) : 0;
    // Barra interna: % QV dentro dos atendimentos desse canal/grupo
    const qvPct   = r.atend  > 0 ? Math.round(r.qv   / r.atend  * 100) : 0;
    // A barra interna ocupa qvPct% da barra externa (proporção visual)
    const qvInner = partPct > 0 ? Math.round(qvPct / 100 * 100) : 0; // % dentro da barra externa

    const barColor     = r.taxa >= 40 ? '#16A34A' : r.taxa >= 30 ? '#0D9488' : r.taxa >= 20 ? '#5B8DEF' : '#EA580C';
    const barColorDark = r.taxa >= 40 ? '#14532D' : r.taxa >= 30 ? '#134E4A' : r.taxa >= 20 ? '#1E3A5F' : '#7C2D12';
    const taxaColor    = r.taxa >= 40 ? '#16A34A' : r.taxa >= 30 ? '#0D9488' : r.taxa >= 20 ? '#D4A017' : '#EA580C';
    const stHtml = r.st ? `<span style="font-size:10px;font-weight:700;color:${r.st.color}">${r.st.label}</span>` : '';

    return `<tr style="background:${isGrupo?'rgba(91,141,239,.06)':'var(--white)'};border-bottom:1px solid var(--border)">
      <td style="padding:9px 14px;font-weight:${isGrupo?700:400};color:${isGrupo?(r.color||'var(--navy)'):'var(--slate)'};font-size:${isGrupo?13:12}px;white-space:nowrap">${r.nome}</td>
      <td style="padding:9px 14px;text-align:center;font-weight:${isGrupo?700:400};color:var(--navy)">${r.atend}</td>
      <td style="padding:9px 14px;text-align:center;font-weight:700;color:#16A34A">${r.qv}</td>
      <td style="padding:9px 14px;text-align:center;font-weight:700;color:${taxaColor}">${(r.taxa||0).toFixed(1)}%</td>
      <td style="padding:9px 16px;min-width:180px">
        <div title="${partPct}% do total de atendimentos · ${qvPct}% viraram QV"
             style="background:#E2E8F0;border-radius:6px;height:18px;width:100%;position:relative;overflow:hidden">
          <!-- barra clara: participação no total -->
          <div style="position:absolute;left:0;top:0;height:100%;width:${partPct}%;background:${barColor};opacity:.35;border-radius:6px"></div>
          <!-- barra escura: % QV dentro da participação -->
          <div style="position:absolute;left:0;top:0;height:100%;width:${partPct * qvInner / 100}%;background:${barColorDark};border-radius:6px"></div>
          <!-- label -->
          <span style="position:absolute;left:${partPct > 20 ? 4 : partPct + 1}%;top:0;line-height:18px;font-size:10px;font-weight:600;color:${partPct > 20 ? '#fff' : 'var(--slate)'}">
            ${partPct}%
          </span>
        </div>
      </td>
      <td style="padding:9px 14px;text-align:right">${stHtml}</td>
    </tr>`;
  }).join('');

  document.getElementById('s6-tabela').innerHTML = `
    <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;font-size:13px;min-width:580px">
      <thead>
        <tr style="background:var(--navy)">
          ${['CANAL','ATEND.','QVs','TAXA QV','PART. %  ·  QV%','STATUS'].map((h,i) =>
            `<th style="padding:10px 14px;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--gold-lt);text-align:${i>=1&&i<=3?'center':i===5?'right':'left'};font-weight:700;white-space:nowrap">${h}</th>`
          ).join('')}
        </tr>
      </thead>
      <tbody>${linhasHtml}</tbody>
    </table>
    </div>`;
}

// ── S6: PASTAS ────────────────────────────────────────────────────────────────
function renderS7(d) {
  const p = d.pastas || {};
  const sfh   = p.sfh   || {};
  const assoc = p.assoc || {};
  const linhas = p.linhas || [];

  document.getElementById('s7-sub').textContent =
    `${(sfh.total||0) + (assoc.total||0)} pastas abertas · Atualizado ${d.gerado_em}`;

  document.getElementById('s7-pastas').innerHTML = `
    <!-- SFH -->
    <div class="pasta-panel" style="--pp-color:#0D9488">
      <div class="pasta-header">
        <h3>DIRETA + SFH</h3>
        <p>Clientes fora do MCMV</p>
      </div>
      <div class="pasta-kpis">
        <div class="pk"><div class="pk-val">${sfh.total||0}</div><div class="pk-lbl">Total</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--green)">${sfh.aprov||0}</div><div class="pk-lbl">Aprovadas</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--red)">${sfh.pend||0}</div><div class="pk-lbl">Pendentes</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--teal)">${pctFmt(sfh.pct_aprov||0)}</div><div class="pk-lbl">Aprovação</div></div>
      </div>
      <table class="pasta-table">
        <thead><tr><th>Equipe</th><th>Pendente</th><th>Aprovada</th><th>Total</th></tr></thead>
        <tbody>
          ${linhas.map(l => `<tr>
            <td>${l.super}</td>
            <td style="color:${l.sfh_pend>0?'var(--red)':'var(--slate-l)'}">${l.sfh_pend}</td>
            <td style="color:var(--green)">${l.sfh_aprov}</td>
            <td>${l.sfh_total}</td>
          </tr>`).join('')}
          <tr><td>TOTAL</td>
            <td style="color:var(--red)">${sfh.pend||0}</td>
            <td style="color:var(--green)">${sfh.aprov||0}</td>
            <td>${sfh.total||0}</td>
          </tr>
        </tbody>
      </table>
      <div class="pasta-note">${sfh.aprov||0} aprovadas · ${sfh.pend||0} pendentes — Perfil de renda qualificado.</div>
    </div>

    <!-- ASSOC -->
    <div class="pasta-panel" style="--pp-color:#7C3AED">
      <div class="pasta-header">
        <h3>ASSOCIATIVO (MCMV)</h3>
        <p>Clientes para Crédito Associativo</p>
      </div>
      <div class="pasta-kpis">
        <div class="pk"><div class="pk-val">${assoc.total||0}</div><div class="pk-lbl">Total</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--red)">${assoc.pend||0}</div><div class="pk-lbl">Pendentes</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--slate-l)">${(d.pastas.linhas||[]).reduce((s,l)=>s+(l.assoc_analise||0),0)}</div><div class="pk-lbl">Em Análise</div></div>
        <div class="pk"><div class="pk-val" style="color:var(--green)">${assoc.sicaq||0}</div><div class="pk-lbl">SICAQ Aprov.</div></div>
      </div>
      <table class="pasta-table">
        <thead><tr><th>Equipe</th><th>Pendente</th><th>Análise</th><th>SICAQ</th><th>Total</th></tr></thead>
        <tbody>
          ${linhas.map(l => `<tr>
            <td>${l.super}</td>
            <td style="color:${l.assoc_pend>0?'var(--red)':'var(--slate-l)'}">${l.assoc_pend}</td>
            <td style="color:var(--slate-l)">${l.assoc_analise}</td>
            <td style="color:var(--green)">${l.assoc_sicaq}</td>
            <td>${l.assoc_total}</td>
          </tr>`).join('')}
          <tr><td>TOTAL</td>
            <td style="color:var(--red)">${assoc.pend||0}</td>
            <td>${(d.pastas.linhas||[]).reduce((s,l)=>s+(l.assoc_analise||0),0)}</td>
            <td style="color:var(--green)">${assoc.sicaq||0}</td>
            <td>${assoc.total||0}</td>
          </tr>
        </tbody>
      </table>
      <div class="pasta-note">${assoc.total||0} pastas · ${assoc.pend||0} pendentes · ${assoc.sicaq||0} aprovados no SICAQ.</div>
    </div>`;
}
</script>
