  document.getElementById('s0-periodo').textContent =
    'Período: Mai–Jun 2026 · Pré-Venda · Atualização ' + d.gerado_em;

  const kpis = [
    { val: t.atend,           lbl: 'Total Atendimentos', color: '#D4A017' },
    { val: t.qv,              lbl: 'QVs Geradas',        color: '#16A34A' },
    { val: pctFmt(t.taxa_qv), lbl: 'Taxa QV Global',     color: '#0D9488' },
    { val: (d.pastas?.sfh?.total||0) + (d.pastas?.assoc?.total||0),
                              lbl: 'Pastas',      color: '#5B8DEF' },
  ];

  document.getElementById('s0-kpis').innerHTML = kpis.map(k => `
    <div class="kpi-card" style="--accent:${k.color}">
