  document.getElementById('s0-fechamento-data').textContent = 'Referência: ' + f.data_fmt;
  const eqColor = { HOUSE:'#5B8DEF', 'UP HOUSE':'#0D9488', MEDI:'#EA580C', PARCERIAS:'#7C3AED' };

  const linhasHtml = (f.linhas || []).map(l => `
    <tr>
      <td style="font-weight:700;color:${eqColor[l.equipe]||'#5B8DEF'};padding:9px 12px;border-bottom:1px solid var(--border)">${l.super}</td>
      <td style="font-size:11px;color:var(--slate-l);padding:9px 12px;border-bottom:1px solid var(--border)">${l.equipe}</td>
      <td style="text-align:center;padding:9px 12px;border-bottom:1px solid var(--border)">${l.VE||0}</td>
      <td style="text-align:center;padding:9px 12px;border-bottom:1px solid var(--border)">${l.I||0}</td>
      <td style="text-align:center;padding:9px 12px;border-bottom:1px solid var(--border)">${l.R||0}</td>
      <td style="text-align:center;padding:9px 12px;border-bottom:1px solid var(--border)">${l.T||0}</td>
      <td style="text-align:center;font-weight:700;color:var(--navy);padding:9px 12px;border-bottom:1px solid var(--border)">${l.total||0}</td>
      <td style="text-align:center;font-weight:700;color:#16A34A;padding:9px 12px;border-bottom:1px solid var(--border)">${l.qv||0}</td>
    </tr>`).join('');

  const tot = f.total || {};
  const totHtml = `
    <tr style="background:var(--navy)">
      <td colspan="2" style="font-weight:800;color:var(--gold-lt);padding:10px 12px">TOTAL</td>
      <td style="text-align:center;color:var(--white);padding:10px 12px">${tot.VE||0}</td>
      <td style="text-align:center;color:var(--white);padding:10px 12px">${tot.I||0}</td>
      <td style="text-align:center;color:var(--white);padding:10px 12px">${tot.R||0}</td>
      <td style="text-align:center;color:var(--white);padding:10px 12px">${tot.T||0}</td>
      <td style="text-align:center;font-weight:800;color:var(--gold-lt);padding:10px 12px">${tot.total||0}</td>
      <td style="text-align:center;font-weight:800;color:#86EFAC;padding:10px 12px">${tot.qv||0}</td>
    </tr>`;

  document.getElementById('s0-fechamento').innerHTML = (!f.linhas || f.linhas.length === 0)
    ? `<div style="color:var(--slate-l);font-size:13px;padding:16px 0">Nenhum atendimento registrado nesta data.</div>`
    : `<div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead>
            <tr style="background:var(--off-white)">
              ${['Super','Equipe','VE','I','R','T','Total','QV'].map((h,i) =>
                `<th style="padding:8px 12px;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--slate);border-bottom:1px solid var(--border);text-align:${i<2?'left':'center'}">${h}</th>`
              ).join('')}
